{
  "name": "serial-logger",
  "version": "0.9.5",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:https": "ng serve --ssl true",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:prod": "npx serve -s dist/serial-logger && open http://localhost:5000",
    "build:prod": "ng build",
    "generate:cmdr-types": "../../.venv1/bin/python ../../scripts/export_cmdr_openapi.py --out tmp/cmdr-openapi.json && npx openapi-typescript tmp/cmdr-openapi.json -o src/app/api/generated/cmdr-api.types.ts",
    "deploy:bauklank-micros-api": "node scripts/deploy-bauklank.mjs",
    "deploy:bauklank-studio": "npm run deploy:bauklank-micros-api"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.6",
    "@angular/common": "^21.2.6",
    "@angular/compiler": "^21.2.6",
    "@angular/core": "^21.2.6",
    "@angular/forms": "^21.2.6",
    "@angular/platform-browser": "^21.2.6",
    "@angular/router": "^21.2.6",
    "@angular/service-worker": "^21.2.6",
    "@primeuix/themes": "^2.0.3",
    "mermaid": "^11.14.0",
    "ngx-markdown": "^21.1.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.3",
    "qr-scanner": "^1.4.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.6",
    "@types/jasmine": "~5.1.0",
    "baseline-browser-mapping": "^2.10.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "openapi-typescript": "^7.10.1",
    "typescript": "~5.9.2"
  }
}
